# Copy to .env and customize. All values have sensible defaults.

# --- Model selection ---
BIOLAB_LLM_MODEL=medgemma:4b
BIOLAB_EMBED_MODEL=nomic-embed-text

# --- Compute ---
BIOLAB_DEVICE=cuda                # cuda | cpu

# --- Fine-tuning ---
BIOLAB_LORA_ADAPTER=/artifacts/lora-protocol-text   # leave empty to use base model; default points at the LFS-tracked adapter

# --- External services (default to compose service names) ---
OLLAMA_HOST=http://ollama:11434
QDRANT_URL=http://qdrant:6333

# --- Paths inside the container ---
BIOLAB_DATA_DIR=/data
BIOLAB_ARTIFACT_DIR=/artifacts

# --- Logging ---
LOG_LEVEL=INFO
